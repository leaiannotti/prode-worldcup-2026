# Database
DATABASE_URL=postgresql://prode:prode@localhost:5432/prode_worldcup
DB_PASSWORD=prode

# Flask
FLASK_ENV=development
SECRET_KEY=dev-secret-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT
JWT_SECRET=your-jwt-secret-key

# Frontend
# Required in production. CORS origin for the backend.
# Local dev defaults to http://localhost:5173 if unset.
FRONTEND_URL=http://localhost:5173

# Webhook
INGESTION_SECRET=your-webhook-secret
